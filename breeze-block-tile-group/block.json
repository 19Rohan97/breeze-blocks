{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "breeze/tile-group",
  "version": "1.2.0",
  "title": "Tile Group",
  "category": "design",
  "icon": "grid-view",
  "description": "A grid of Bricks component blocks — each tile individually editable",
  "keywords": ["tiles", "grid", "bricks", "component", "cards"],
  "textdomain": "breeze-block-tile-group",
  "attributes": {
    "columns": {
      "type": "number",
      "default": 3
    },
    "columnsTablet": {
      "type": "number",
      "default": 2
    },
    "columnsMobile": {
      "type": "number",
      "default": 1
    },
    "gap": {
      "type": "string",
      "default": "24px"
    },
    "rowGap": {
      "type": "string",
      "default": ""
    },
    "verticalAlign": {
      "type": "string",
      "default": "stretch"
    },
    "componentId": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "align": ["wide", "full"],
    "spacing": {
      "padding": true,
      "margin": true
    },
    "html": false
  },
  "editorScript": "file:./block.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css",
  "render": "file:./template.php"
}
